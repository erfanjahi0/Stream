# ──────────────────────────────────────────────
# StreamForge Environment Configuration
# ──────────────────────────────────────────────

# Port the web app listens on (Railway sets this automatically)
PORT=3000

# YouTube RTMP stream key + URL
# Get this from YouTube Studio → Create → Go Live → Stream
YOUTUBE_RTMP_URL=rtmp://a.rtmp.youtube.com/live2
YOUTUBE_STREAM_KEY=your-stream-key-here

# Optional: override ffmpeg binary path (Railway nixpacks usually auto-detects)
# FFMPEG_PATH=/usr/bin/ffmpeg

# Download directory — uses Railway ephemeral container storage (up to 1TB)
# No persistent volume needed. Files are cleaned up after stream ends.
DOWNLOAD_DIR=/tmp/streamforge/downloads

# Set to 'false' to keep downloaded files after stream ends (uses more storage)
CLEANUP_FILES=true

# Max concurrent streams
MAX_CONCURRENT_STREAMS=3

# Chunk size for Google Drive streaming (bytes) — 10MB default
CHUNK_SIZE=10485760
